# ============================================================
# QuickScan 2.0 Backend — Environment Variables
# ============================================================

# --- PostgreSQL Database ---
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=quickscan_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- PASETO Token Encryption (MUST be exactly 32 characters) ---
PASETO_SECRET_KEY=CHANGE_ME_32_CHAR_SECRET_KEY_HERE

# --- Google OAuth2 (Optional — leave empty to disable SSO) ---
# Get yours at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
